{
  "name": "diffuse",
  "version": "1.0.0",
  "description": "CSS diff tool — paste two stylesheets, see exactly what changed.",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-order": "^6.0.0"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "eslint --max-warnings 0"
    ],
    "*.css": [
      "prettier --write",
      "stylelint --fix"
    ],
    "*.html": [
      "prettier --write"
    ]
  }
}
