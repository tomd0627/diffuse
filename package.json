{
  "name": "diffuse",
  "version": "1.0.0",
  "description": "CSS diff tool — paste two stylesheets, see exactly what changed.",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.10.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "eslint --max-warnings 0"
    ],
    "*.css": [
      "prettier --write",
      "stylelint --fix"
    ],
    "*.html": [
      "prettier --write"
    ]
  }
}
